# Database (SQLite; file at api/prisma/dev.db)
DATABASE_URL="file:./dev.db"

# API server port (default 4000)
PORT=4000

# CORS: allow the frontend origin (Vite default 5173). In production set to your app URL.
FRONTEND_ORIGIN=http://localhost:5173

# Obsidian export (MVP): absolute vault path for direct-write manual export.
# Example (Linux): /home/you/Documents/ObsidianVault
OBSIDIAN_VAULT_ROOT=
